PPIO_API_KEY=replace_with_your_ppio_key
PPIO_BASE_URL=https://api.ppinfra.com/v3/openai
PPIO_MODEL=deepseek/deepseek-v3-turbo
PPIO_TIMEOUT_MS=30000
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
NEXT_PUBLIC_MOCK_PRODUCT_URL=http://127.0.0.1:4000
AUTH_SECRET=replace_with_random_32_byte_secret
DATABASE_URL=postgresql://user:password@host:5432/atpio
# Optional migration fallback account. Normal users can register at /register.
ATPIO_ADMIN_EMAIL=admin@example.com
ATPIO_ADMIN_PASSWORD=replace_with_a_strong_password
